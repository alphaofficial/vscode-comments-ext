{
  "name": "margin",
  "displayName": "Margin",
  "description": "Private, local-only code review comments for VS Code.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "margin.addThread",
        "title": "Margin: Add Comment Thread"
      },
      {
        "command": "margin.addReply",
        "title": "Margin: Add Reply"
      },
      {
        "command": "margin.resolve",
        "title": "Margin: Resolve Thread"
      },
      {
        "command": "margin.reopen",
        "title": "Margin: Reopen Thread"
      },
      {
        "command": "margin.deleteThread",
        "title": "Margin: Delete Thread"
      },
      {
        "command": "margin.init",
        "title": "Margin: Initialize Margin"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "node --experimental-default-type=module --import ./register-ts-hooks.mjs --test"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.3",
    "vsce": "^2.15.0"
  }
}
